# ===============================================================
# ARVIND PARTY WEB PANEL — Environment Variables
# ===============================================================
#
# Copy this file to .env and fill in the values, OR pass them
# directly via --dart-define at build/run time.
#
# Production defaults: API → https://api.arvindparty.com
#                      LiveKit → wss://livekit.arvindparty.com
# ===============================================================

# Backend API
API_BASE_URL=http://localhost:5000/api

# Socket.IO server
SOCKET_URL=http://localhost:5000

# --- Firebase (required for Google Sign-In auth) ---
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# LiveKit streaming server (optional for monitoring views)
LIVEKIT_URL=wss://livekit.arvindparty.com

# Razorpay payment key
RAZORPAY_KEY_ID=rzp_live_...
